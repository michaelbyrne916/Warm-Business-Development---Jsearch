    {
      "parameters": {
        "content": "## WF4: Approved Send\n\nSends approved outreach emails. Human must set approval_status='approved' in Outreach Queue tab first.\n\n**Flow:**\n1. Read Outreach Queue: approval_status=approved, sent_status=unsent\n2. Suppression check (30-day dedup window)\n3. DRY_RUN gate â€” set DRY_RUN=true to preview without sending\n4. Send via Gmail\n5. Write to Sent Log\n6. Update Outreach Queue + Opportunities status\n7. Add to Suppression List\n\n**Schedule:** Every 2hrs, Mon-Fri 8am-4pm\n\n**SAFETY:**\n- Set DRY_RUN=true to test\n- No email sent until approval_status=approved\n- Suppression prevents duplicate sends\n\n**Env vars needed:**\n- GOOGLE_SHEETS_ID\n- GMAIL_SENDER\n- DUPLICATE_SUPPRESSION_DAYS\n- DRY_RUN",
        "height": 360,
        "width": 280
      },
      "id": "wf4-sticky",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -208,
        208
      ]
    },
    {
      "id": "wf4-build-followups",
      "name": "Build Follow-up Sequence",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3312,
        288
      ],
      "parameters": {
        "jsCode": "// Build follow-up queue entries from actual Gmail sends (post-send truth)\n// Source: Send via Gmail output — items that have a real Gmail message id\n// Stage 1 (email 2): triggered when stage 0 sends — 3 business days out\n// Stage 2 (email 3): triggered when stage 1 sends — 7 calendar days out\n\nconst results = [];\nconst now = new Date();\n\nconst addCalendarDays = (d, n) => {\n  const r = new Date(d);\n  r.setDate(r.getDate() + n);\n  return r.toISOString().split('T')[0];\n};\n\nconst addBusinessDays = (d, n) => {\n  const r = new Date(d);\n  let added = 0;\n  while (added < n) {\n    r.setDate(r.getDate() + 1);\n    const dow = r.getDay();\n    if (dow !== 0 && dow !== 6) added++; // skip weekends\n  }\n  return r.toISOString().split('T')[0];\n};\n\nconst sentItems = $('Send via Gmail').all();\n\nfor (const sentItem of sentItems) {\n  // Filter: only real Gmail successes (has message id, no error)\n  const gmailResp = sentItem.json;\n  if (!gmailResp || gmailResp.error || !gmailResp.id) {\n    continue;\n  }\n\n  // Back-reference original contact data via pairedItem\n  let data;\n  try {\n    data = $('Prepare Send Fields').itemMatching(sentItem.pairedItem.item).json;\n  } catch (e) {\n    continue; // no matching source item — skip rather than fabricate\n  }\n  if (!data) continue;\n\n  const stage = parseInt(data.follow_up_stage || '0', 10);\n\n  if (stage === 0) {\n    // Email 1 just sent — queue Email 2 for 3 business days from now\n    results.push({ json: {\n      opportunity_id: data.opportunity_id || '',\n      contact_email: data.contact_email || '',\n      contact_name: data.contact_name || '',\n      company_name: data.company_name || '',\n      company_domain: data.company_domain || '',\n      job_title: data.job_title || '',\n      location: data.location || '',\n      email_1_subject: data.email_1_subject || '',\n      email_1_body: data.email_1_body || '',\n      email_2_subject: data.email_2_subject || '',\n      email_2_body: data.email_2_body || '',\n      email_3_subject: data.email_3_subject || '',\n      email_3_body: data.email_3_body || '',\n      email_body: data.email_2_body || '',          // what Prepare Send Fields reads\n      approval_status: 'approved',\n      sent_status: 'unsent',\n      follow_up_stage: 1,\n      scheduled_date: addBusinessDays(now, 3),\n      posted_date: data.posted_date || '',\n      source_url: data.source_url || ''\n    }});\n\n  } else if (stage === 1) {\n    // Email 2 just sent — queue Email 3 for 7 calendar days from now\n    results.push({ json: {\n      opportunity_id: data.opportunity_id || '',\n      contact_email: data.contact_email || '',\n      contact_name: data.contact_name || '',\n      company_name: data.company_name || '',\n      company_domain: data.company_domain || '',\n      job_title: data.job_title || '',\n      location: data.location || '',\n      email_1_subject: data.email_1_subject || '',\n      email_1_body: data.email_1_body || '',\n      email_2_subject: data.email_2_subject || '',\n      email_2_body: data.email_2_body || '',\n      email_3_subject: data.email_3_subject || '',\n      email_3_body: data.email_3_body || '',\n      email_body: data.email_3_body || '',          // what Prepare Send Fields reads\n      approval_status: 'approved',\n      sent_status: 'unsent',\n      follow_up_stage: 2,\n      scheduled_date: addCalendarDays(now, 7),\n      posted_date: data.posted_date || '',\n      source_url: data.source_url || ''\n    }});\n  }\n  // stage 2 (email 3) — no further follow-ups\n}\n\nreturn results;"
      }
    },
