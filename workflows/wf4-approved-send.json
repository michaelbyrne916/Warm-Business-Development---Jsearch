      "parameters": {
        "jsCode": "// Build suppression map from input (Read Suppression List)\nconst suppressionRows = $input.all().map(i => i.json);\nconst suppressionMap = new Map();\nfor (const row of suppressionRows) {\n  const key = `${(row.company_domain || '').toLowerCase()}|${(row.contact_email || '').toLowerCase()}`;\n  if (row.suppressed_until) {\n    suppressionMap.set(key, new Date(row.suppressed_until));\n  }\n}\n\n// Filter approved, unsent, due rows from Outreach Queue\nconst today = new Date();\ntoday.setHours(23, 59, 59, 999);\nconst now = new Date();\n\nconst allApproved = $('Read Approved Rows').all();\nconst approvedRows = allApproved.filter(item => {\n  const approvalStatus = (item.json.approval_status || '').trim().toLowerCase();\n  if (approvalStatus !== 'approved') return false;\n  const sentStatus = (item.json.sent_status || '').trim().toLowerCase();\n  if (sentStatus !== 'unsent') return false;\n  const scheduledDate = (item.json.scheduled_date || '').trim();\n  if (!scheduledDate) return true;\n  return new Date(scheduledDate) <= today;\n});\n\n// Check suppression and deduplicate within batch — no serialization\nconst seen = new Set();\n\nreturn approvedRows.map(item => {\n  const row = { ...item.json };\n  const key = `${(row.company_domain || '').toLowerCase()}|${(row.contact_email || '').toLowerCase()}`;\n  const followUpStage = parseInt(row.follow_up_stage || '0');\n\n  let isSuppressed = false;\n  let suppressionReason = '';\n\n  // Only check suppression for stage 0 (initial email)\n  if (followUpStage === 0 && suppressionMap.has(key)) {\n    const suppressedUntil = suppressionMap.get(key);\n    if (now < suppressedUntil) {\n      isSuppressed = true;\n      suppressionReason = `In suppression list until ${suppressedUntil.toISOString().split('T')[0]}`;\n    }\n  }\n\n  // Deduplicate within this batch\n  if (seen.has(key)) {\n    isSuppressed = true;\n    suppressionReason = 'Duplicate in current batch';\n  }\n  seen.add(key);\n\n  row._is_suppressed = isSuppressed;\n  row._suppression_reason = suppressionReason;\n\n  return { json: row };\n});"
      },
