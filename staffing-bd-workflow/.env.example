# ============================================================
# Staffing BD Workflow — Environment Variables
# Copy this file to .env and fill in your values.
# In n8n Cloud: add each variable under Settings > Variables
# In self-hosted n8n: set as environment variables or in .env
# ============================================================

# ----------------------------------------------------------
# JOB SOURCE — JSearch via RapidAPI
# Sign up: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# ----------------------------------------------------------
JSEARCH_API_KEY=your_rapidapi_key_here
JSEARCH_API_HOST=jsearch.p.rapidapi.com

# ----------------------------------------------------------
# COMPANY ENRICHMENT — Clearbit
# Sign up: https://dashboard.clearbit.com/
# Free tier: 50 enrichments/month
# ----------------------------------------------------------
CLEARBIT_API_KEY=your_clearbit_api_key_here

# ----------------------------------------------------------
# CONTACT DISCOVERY — Hunter.io
# Sign up: https://hunter.io/
# Free tier: 25 domain searches/month
# ----------------------------------------------------------
HUNTER_API_KEY=your_hunter_io_api_key_here

# ----------------------------------------------------------
# LLM PROVIDER — Toggle between OpenAI and Anthropic
# Set LLM_PROVIDER to "openai" or "anthropic"
# ----------------------------------------------------------
LLM_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-6

# ----------------------------------------------------------
# GOOGLE
# GOOGLE_SHEETS_ID: from the URL of your sheet
#   https://docs.google.com/spreadsheets/d/SHEET_ID/edit
# GOOGLE_DOCS_FOLDER_ID: from the URL of your Drive folder
#   https://drive.google.com/drive/folders/FOLDER_ID
# ----------------------------------------------------------
GOOGLE_SHEETS_ID=your_google_sheet_id_here
GOOGLE_DOCS_FOLDER_ID=your_google_drive_folder_id_here
GMAIL_SENDER=your.email@gmail.com

# ----------------------------------------------------------
# WORKFLOW CHAIN IDs (fill in after creating workflows)
# Get IDs from n8n after import: Settings > ID shown in URL
# ----------------------------------------------------------
WF2_CONTACT_DISCOVERY_ID=2uWLVQ4JS1zXwztO
WF3_OUTREACH_DRAFT_ID=T1jTXreAw0uZ2TOD

# ----------------------------------------------------------
# BEHAVIOR CONTROLS
# ----------------------------------------------------------
# APPROVAL_REQUIRED: always true for safety
APPROVAL_REQUIRED=true

# DRY_RUN: set true to test WF4 without sending real emails
DRY_RUN=true

# DUPLICATE_SUPPRESSION_DAYS: days to suppress re-outreach to same contact
DUPLICATE_SUPPRESSION_DAYS=30

# MIN_MATCH_SCORE: minimum job match score (0-100) to continue processing
MIN_MATCH_SCORE=60

# MIN_CONFIDENCE_SCORE: minimum contact confidence score to auto-proceed
MIN_CONFIDENCE_SCORE=70
